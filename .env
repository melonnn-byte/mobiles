# URL API Backend untuk Early Warning System
# Gunakan 10.0.2.2 jika kamu menggunakan Emulator Android bawaan Google
# Gunakan localhost jika kamu mencoba menjalankan di Windows/Web
# Gunakan IP Laptop (misal 192.168.1.5) jika kamu menggunakan HP fisik lewat Wi-Fi
API_URL="http://10.0.2.2:3001/api"

# Jika kamu sudah mengisi Firebase config, gunakan variabel berikut:
# FIREBASE_API_KEY="..."
# FIREBASE_APP_ID="..."
# FIREBASE_PROJECT_ID="..."
# FIREBASE_MESSAGING_SENDER_ID="..."
# FIREBASE_AUTH_DOMAIN="..."
# FIREBASE_STORAGE_BUCKET="..."
# FIREBASE_MEASUREMENT_ID="..."
# FIREBASE_IOS_BUNDLE_ID="..."

# Jika kamu ingin menambahkan konfigurasi lain nanti
APP_NAME="EWS Flood Guard"